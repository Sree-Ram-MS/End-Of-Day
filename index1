<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>End-of-Day Closing Procedure</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    /* RESET & BASE */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0d1b2a;
      color: #e2eaf4;
      min-height: 100vh;
      padding-bottom: 80px;
    }

    /* HERO SECTION */
    .hero {
      text-align: center;
      padding: 50px 24px 20px;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: rgba(59,158,255,0.1);
      border: 1px solid rgba(59,158,255,0.25);
      color: #7ec8ff;
      font-size: 12px;
      font-weight: 600;
      padding: 6px 16px;
      border-radius: 50px;
      margin-bottom: 20px;
    }
    .hero h1 {
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 800;
      color: #ffffff;
    }
    .gradient {
      background: linear-gradient(90deg, #3b9eff, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* PROGRESS TRACKER */
    .progress-card {
      max-width: 850px;
      margin: 10px auto 40px;
      background: #132035;
      border: 1px solid #1e3a5f;
      border-radius: 16px;
      padding: 24px;
    }
    .progress-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-end; /* Aligns clock and percentage to bottom */
      margin-bottom: 15px;
    }
    
    .date-time-group .date {
      font-size: 0.9rem;
      color: #6b8cbc;
      margin-bottom: 4px;
      font-weight: 500;
    }
    .date-time-group .time {
      font-size: 1.6rem;
      font-weight: 700;
      color: #fff;
    }

    .status-group {
      text-align: right;
    }
    .status-text { 
      font-size: 0.9rem; 
      color: #6b8cbc;
      margin-bottom: 4px;
    }
    .pct-large {
      font-size: 1.6rem;
      font-weight: 800;
      color: #fff;
    }

    .progress-bar-wrap {
      background: #0d1b2a;
      height: 8px;
      border-radius: 10px;
      overflow: hidden;
      clear: both;
    }
    .progress-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, #3b9eff, #a78bfa);
      width: 0%;
      transition: width 0.4s ease;
    }

    /* STEPS CONTAINER */
    .steps-wrap {
      max-width: 850px;
      margin: 0 auto;
      padding: 0 20px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    /* STEP CARD */
    .step-card {
      background: #132035;
      border: 1px solid #1e3a5f;
      border-radius: 14px;
      padding: 20px;
      display: flex;
      gap: 20px;
      transition: all 0.3s ease;
    }
    .step-card.done {
      opacity: 0.5;
      border-color: #27ae60;
      background: #0f2218;
    }

    .checkbox {
      width: 26px;
      height: 26px;
      border: 2px solid #2c4f7c;
      border-radius: 8px;
      cursor: pointer;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .step-card.done .checkbox {
      background: #27ae60;
      border-color: #27ae60;
    }
    .check-icon {
      width: 16px;
      height: 16px;
      color: white;
      display: none;
    }
    .step-card.done .check-icon { display: block; }

    .step-body {
      flex: 1;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
    }
    .step-info { flex: 1; }
    .step-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 8px;
    }
    .step-num { color: #3b9eff; margin-right: 8px; }
    .step-desc {
      font-size: 0.95rem;
      color: #6b8cbc;
      line-height: 1.6;
    }
    .note {
      margin-top: 10px;
      font-size: 0.85rem;
      color: #d4a827;
      background: rgba(212, 168, 39, 0.1);
      padding: 8px 12px;
      border-radius: 6px;
      border-left: 3px solid #d4a827;
    }

    .step-img-box {
      width: 220px;
      height: 140px;
      flex-shrink: 0;
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid #1e3a5f;
      background: #000;
    }
    .step-img-box img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    #completion-msg {
      display: none;
      text-align: center;
      background: #27ae60;
      color: white;
      padding: 15px;
      border-radius: 10px;
      margin-bottom: 20px;
      font-weight: 700;
    }

    @media (max-width: 650px) {
      .step-body { flex-direction: column; }
      .step-img-box { width: 100%; height: 200px; }
    }
  </style>
</head>
<body>

  <div class="hero">
    <div class="hero-badge">OFFICE OPERATIONS</div>
    <h1>End-of-Day <span class="gradient">Closing</span></h1>
  </div>

  <div class="progress-card">
    <div id="completion-msg">✅ ALL STEPS COMPLETE. PREMISES SECURED.</div>
    <div class="progress-top">
      <div class="date-time-group">
        <div class="date" id="current-date">Monday, April 13, 2026</div>
        <div class="time" id="clock">00:00:00 AM</div>
      </div>
      <div class="status-group">
        <div class="status-text" id="progress-text">0 of 9 steps completed</div>
        <div class="pct-large" id="pct-display">0%</div>
      </div>
    </div>
    <div class="progress-bar-wrap">
      <div class="progress-bar-fill" id="progress-bar"></div>
    </div>
  </div>

  <div class="steps-wrap">
    
    <div class="step-card" id="step-1">
      <div class="checkbox" onclick="toggleStep(1)">
        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="step-body">
        <div class="step-info">
          <div class="step-title"><span class="step-num">01.</span> Climate Control</div>
          <div class="step-desc">Switch OFF the AC using the remote and wait until the air ventilator closes completely.</div>
        </div>
        <div class="step-img-box">
          <img src="https://your-github-link.com/image1.jpg" alt="AC Step">
        </div>
      </div>
    </div>

    <div class="step-card" id="step-2">
      <div class="checkbox" onclick="toggleStep(2)">
        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="step-body">
        <div class="step-info">
          <div class="step-title"><span class="step-num">02.</span> Distribution Board (DB)</div>
          <div class="step-desc">Go to the main DB area and gently push the door; it will open.</div>
        </div>
        <div class="step-img-box">
          <img src="https://your-github-link.com/image2.jpg" alt="DB Area">
        </div>
      </div>
    </div>

    <div class="step-card" id="step-3">
      <div class="checkbox" onclick="toggleStep(3)">
        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="step-body">
        <div class="step-info">
          <div class="step-title"><span class="step-num">03.</span> Master Switches</div>
          <div class="step-desc">Turn OFF all light switches and the AC master switch.</div>
          <div class="note">Note: Camera lights will turn ON automatically within 5s.</div>
        </div>
        <div class="step-img-box">
          <img src="https://your-github-link.com/image3.jpg" alt="Switches">
        </div>
      </div>
    </div>

    <div class="step-card" id="step-4">
      <div class="checkbox" onclick="toggleStep(4)">
        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="step-body">
        <div class="step-info">
          <div class="step-title"><span class="step-num">04.</span> Washrooms & Doors</div>
          <div class="step-desc">Verify washroom lights and fans are OFF. Lock all doors using Key or Biometric system.</div>
        </div>
        <div class="step-img-box">
          <img src="https://your-github-link.com/image4.jpg" alt="Locks">
        </div>
      </div>
    </div>

    <div class="step-card" id="step-5">
      <div class="checkbox" onclick="toggleStep(5)">
        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="step-body">
        <div class="step-info">
          <div class="step-title"><span class="step-num">05.</span> Stairway & Ground Floor</div>
          <div class="step-desc">Switch OFF all stairway and ground floor lights.</div>
          <div class="note">Crucial: Keep the three front bulbs ON.</div>
        </div>
        <div class="step-img-box">
          <img src="https://your-github-link.com/image5.jpg" alt="Lights">
        </div>
      </div>
    </div>

    <div class="step-card" id="step-6">
      <div class="checkbox" onclick="toggleStep(6)">
        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="step-body">
        <div class="step-info">
          <div class="step-title"><span class="step-num">06.</span> Kitchen Check</div>
          <div class="step-desc">Check the kitchen area and ensure that the lights and fan are switched OFF.</div>
        </div>
        <div class="step-img-box">
          <img src="https://your-github-link.com/image6.jpg" alt="Kitchen">
        </div>
      </div>
    </div>

    <div class="step-card" id="step-7">
      <div class="checkbox" onclick="toggleStep(7)">
        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="step-body">
        <div class="step-info">
          <div class="step-title"><span class="step-num">07.</span> External Shutters</div>
          <div class="step-desc">Close all shutters. Use the two iron rods provided to pull them down safely.</div>
        </div>
        <div class="step-img-box">
          <img src="https://your-github-link.com/image7.jpg" alt="Shutters">
        </div>
      </div>
    </div>

    <div class="step-card" id="step-8">
      <div class="checkbox" onclick="toggleStep(8)">
        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="step-body">
        <div class="step-info">
          <div class="step-title"><span class="step-num">08.</span> Gate & Perimeter</div>
          <div class="step-desc">Close the main gate and secure the area using the chain partition.</div>
        </div>
        <div class="step-img-box">
          <img src="https://your-github-link.com/image8.jpg" alt="Gate">
        </div>
      </div>
    </div>

    <div class="step-card" id="step-9">
      <div class="checkbox" onclick="toggleStep(9)">
        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="step-body">
        <div class="step-info">
          <div class="step-title"><span class="step-num">09.</span> Key Handover</div>
          <div class="step-desc">Hand over all keys to the Security team at HQ.</div>
        </div>
        <div class="step-img-box" style="display:flex; align-items:center; justify-content:center; background:#1e3a5f; color:#7ec8ff; font-size:2rem;">
          🔑
        </div>
      </div>
    </div>

  </div>

  <script>
    const total = 9;
    let completed = new Set();

    function toggleStep(n) {
      const card = document.getElementById('step-' + n);
      if (completed.has(n)) {
        completed.delete(n);
        card.classList.remove('done');
      } else {
        completed.add(n);
        card.classList.add('done');
      }
      updateProgress();
    }

    function updateProgress() {
      const count = completed.size;
      const pct = Math.round((count / total) * 100);
      document.getElementById('progress-bar').style.width = pct + '%';
      document.getElementById('progress-text').textContent = `${count} of ${total} steps completed`;
      document.getElementById('pct-display').textContent = pct + '%';
      
      const msg = document.getElementById('completion-msg');
      msg.style.display = (count === total) ? 'block' : 'none';
    }

    function startClock() {
      setInterval(() => {
        const now = new Date();
        // Update Time
        document.getElementById('clock').textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true });
        
        // Update Date
        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        document.getElementById('current-date').textContent = now.toLocaleDateString('en-US', options);
      }, 1000);
    }
    startClock();
  </script>
</body>
</html>
